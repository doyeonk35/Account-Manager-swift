    "onboarding.addAccount.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click the + button in the toolbar to add a new account.\nEnter a title, TVING ID, password,\naccount type (QC/QA), and plan type."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "툴바의 + 버튼을 클릭하여 새 계정을 추가하세요.\n제목, TVING ID, 비밀번호,\n계정 유형(QC/QA), 요금제를 입력합니다."
          }
        }
      }
    },
    "onboarding.addAccount.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add Account"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정 등록"
          }
        }
      }
    },
    "onboarding.import.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to Settings > General and click Open Import Folder.\nUse presets.example.json as a template —\nrename it to presets.json, fill in your accounts,\nthen click Import. Duplicates are automatically skipped."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "설정 > 일반에서 불러오기 폴더 열기를 클릭하세요.\npresets.example.json을 양식으로 활용하여\npresets.json으로 이름을 바꾸고 계정을 입력한 뒤\n불러오기를 클릭하면 됩니다. 중복 계정은 자동으로 건너뜁니다."
          }
        }
      }
    },
    "onboarding.import.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bulk Import"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정 일괄 등록"
          }
        }
      }
    },
    "onboarding.login.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click the Login button next to any account.\nA browser window opens and automatically\nfills in your ID and password."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정 옆의 Login 버튼을 클릭하세요.\n브라우저 창이 열리고 자동으로\nID와 비밀번호가 입력됩니다."
          }
        }
      }
    },
    "onboarding.login.title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
