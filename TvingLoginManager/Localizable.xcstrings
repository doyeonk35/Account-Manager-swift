        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enter a 6-digit OTP code at the top of the account list.\nThe code is automatically applied\nwhen logging in to accounts that require OTP."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정 목록 상단에 6자리 OTP 코드를 입력하세요.\nOTP가 필요한 계정 로그인 시\n자동으로 코드가 적용됩니다."
          }
        }
      }
    },
